// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  username    String   @unique
  password    String
  accountType AccountType @default(USER)
  avatar      String?
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  projects    Project[]
  likes       Like[]
  comments    Comment[]
  deals       Deal[] @relation("BuyerDeals")
  soldDeals   Deal[] @relation("SellerDeals")

  @@map("users")
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  slug        String   @unique
  price       Float
  category    String
  tags        String   // JSON string for array
  demoUrl     String?
  githubUrl   String?
  images      String   // JSON string for array
  status      ProjectStatus @default(DRAFT)
  thumbnailUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes       Like[]
  comments    Comment[]
  deals       Deal[]
  files       CodeFile[]
  folders     CodeFolder[]
  versions    ProjectVersion[]

  @@map("projects")
}

model CodeFile {
  id          String   @id @default(cuid())
  name        String
  content     String   @db.Text
  language    String
  size        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folderId     String?
  folder      CodeFolder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@map("code_files")
}

model CodeFolder {
  id          String   @id @default(cuid())
  name        String
  path        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      CodeFolder? @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    CodeFolder[] @relation("FolderHierarchy")
  files       CodeFile[]

  @@map("code_folders")
}

model ProjectVersion {
  id          String   @id @default(cuid())
  version     String
  description String?
  createdAt   DateTime @default(now())

  // Relations
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_versions")
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("likes")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Deal {
  id          String     @id @default(cuid())
  price       Float
  status      DealStatus @default(PENDING)
  type        DealType   @default(BUY)
  message     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  buyerId     String
  sellerId    String
  projectId   String
  
  buyer       User       @relation("BuyerDeals", fields: [buyerId], references: [id])
  seller      User       @relation("SellerDeals", fields: [sellerId], references: [id])
  project     Project    @relation(fields: [projectId], references: [id])

  @@map("deals")
}

enum AccountType {
  USER
  DEVELOPER
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  SOLD
}

enum DealStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

enum DealType {
  BUY
  LICENSE
}
